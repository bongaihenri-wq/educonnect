// lib/services/admin_stats_service.dart
import 'package:supabase_flutter/supabase_flutter.dart';

class AdminStatsService {
  static final AdminStatsService _instance = AdminStatsService._internal();
  factory AdminStatsService() => _instance;
  AdminStatsService._internal();

  final _client = Supabase.instance.client;

  /// Récupère toutes les stats d'une école
  Future<Map<String, dynamic>> getSchoolStats(String schoolId) async {
    try {
      // 1. Compter les élèves
      final studentsCount = await _client
          .from('students')
          .select('id', const FetchOptions(count: CountOption.exact))
          .eq('school_id', schoolId);

      // 2. Compter les classes
      final classesCount = await _client
          .from('classes')
          .select('id', const FetchOptions(count: CountOption.exact))
          .eq('school_id', schoolId);

      // 3. Compter les enseignants (via user_roles)
      final teachersCount = await _client
          .from('user_roles')
          .select('user_id', const FetchOptions(count: CountOption.exact))
          .eq('school_id', schoolId)
          .eq('role', 'teacher');

      // 4. Compter les parents
      final parentsCount = await _client
          .from('parents')
          .select('id', const FetchOptions(count: CountOption.exact))
          .eq('school_id', schoolId);

      // 5. Stats de présence globale
      final attendanceStats = await _client
          .rpc('get_school_attendance_stats', params: {'p_school_id': schoolId});

      // 6. Moyenne générale des notes
      final gradesAvg = await _client
          .from('grades')
          .select('value')
          .eq('school_id', schoolId);

      double averageGrade = 0;
      if (gradesAvg.isNotEmpty) {
        final values = gradesAvg.map((g) => (g['value'] as num).toDouble()).toList();
        averageGrade = values.reduce((a, b) => a + b) / values.length;
      }

      return {
        'students': studentsCount.length,
        'classes': classesCount.length,
        'teachers': teachersCount.length,
        'parents': parentsCount.length,
        'attendance': attendanceStats ?? {'present_rate': 0, 'absent_rate': 0},
        'average_grade': averageGrade.toStringAsFixed(2),
        'loading': false,
        'error': null,
      };
    } catch (e) {
      return {
        'students': 0,
        'classes': 0,
        'teachers': 0,
        'parents': 0,
        'attendance': {'present_rate': 0, 'absent_rate': 0},
        'average_grade': '0.00',
        'loading': false,
        'error': e.toString(),
      };
    }
  }

  /// Récupère les stats par classe
  Future<List<Map<String, dynamic>>> getClassesStats(String schoolId) async {
    try {
      final response = await _client
          .from('classes')
          .select('id, name, level, students:students(count), schedules:schedules(count), grades:grades(count)')
          .eq('school_id', schoolId)
          .order('name');

      return List<Map<String, dynamic>>.from(response);
    } catch (e) {
      print('❌ Erreur getClassesStats: $e');
      return [];
    }
  }

  /// Récupère les stats des enseignants
  Future<List<Map<String, dynamic>>> getTeachersStats(String schoolId) async {
    try {
      final response = await _client
          .from('user_roles')
          .select('user_id, app_users!inner(first_name, last_name, email, phone), classes:classes!teacher_id(count), schedules:schedules!teacher_id(count), attendance:attendance!teacher_id(count)')
          .eq('school_id', schoolId)
          .eq('role', 'teacher');

      return List<Map<String, dynamic>>.from(response);
    } catch (e) {
      print('❌ Erreur getTeachersStats: $e');
      return [];
    }
  }

  /// Récupère le taux de présence par enseignant
  Future<Map<String, dynamic>> getTeacherAttendanceStats(
    String schoolId,
    String teacherId,
  ) async {
    try {
      // Nombre d'appels faits par l'enseignant ce mois
      final callsThisMonth = await _client
          .from('attendance')
          .select('id', const FetchOptions(count: CountOption.exact))
          .eq('school_id', schoolId)
          .eq('teacher_id', teacherId)
          .gte('date', DateTime.now().subtract(const Duration(days: 30)).toIso8601String());

      // Nombre de cours programmés pour cet enseignant
      final scheduledCourses = await _client
          .from('schedules')
          .select('id', const FetchOptions(count: CountOption.exact))
          .eq('school_id', schoolId)
          .eq('teacher_id', teacherId);

      // Taux de présence des élèves dans ses cours
      final studentAttendance = await _client
          .from('attendance')
          .select('status')
          .eq('school_id', schoolId)
          .eq('teacher_id', teacherId);

      int present = 0;
      int total = studentAttendance.length;
      for (var a in studentAttendance) {
        if (a['status'] == 'present') present++;
      }

      return {
        'calls_this_month': callsThisMonth.length,
        'scheduled_courses': scheduledCourses.length,
        'student_presence_rate': total > 0 ? (present / total * 100).round() : 0,
        'total_attendance_records': total,
      };
    } catch (e) {
      print('❌ Erreur getTeacherAttendanceStats: $e');
      return {
        'calls_this_month': 0,
        'scheduled_courses': 0,
        'student_presence_rate': 0,
        'total_attendance_records': 0,
      };
    }
  }
}